# ============================================================
# Unified Backend .env — Voice, OCR, Summarization, Conversational AI
# Copy to .env and fill in your values.
# ============================================================

# --- Local GGUF (Qwen chat + Jina embeddings via llama-cpp-python) ---
# Set LLM_PROVIDER=local (default) and absolute paths to each .gguf file.
# Hugging Face Hub cache layout (Windows example):
#   C:\Users\<you>\.cache\huggingface\hub\models--<org>--<repo>\snapshots\<hash>\*.gguf
# Never use paths under ".no_exist" — re-download with the HF CLI (in venv it is `hf`, not huggingface-cli), e.g.:
#   .\.venv\Scripts\hf.exe download unsloth/Qwen3.5-9B-GGUF Qwen3.5-9B-Q6_K.gguf
# Find files: Get-ChildItem -Path "$env:USERPROFILE\.cache\huggingface\hub" -Recurse -Filter "*.gguf"
# LLAMA_VERBOSE=true
LLM_PROVIDER=local
# LOCAL_CHAT_GGUF_PATH=C:\Users\<you>\.cache\huggingface\hub\models--Qwen--…\snapshots\<hash>\file.gguf
# LOCAL_EMBEDDING_GGUF_PATH=C:\Users\<you>\.cache\huggingface\hub\models--jinaai--…\snapshots\<hash>\file.gguf
LOCAL_CHAT_GGUF_PATH=
LOCAL_EMBEDDING_GGUF_PATH=
# auto = Query:/Passage: + normalize for paths containing jina+retrieval (PRD FAISS + Advanced RAG convention)
# LOCAL_EMBEDDING_JINA_PREFIXES=auto
# --- GPU (all local llama.cpp): -1 = offload all layers; 0 = CPU only. Needs CUDA-enabled llama-cpp-python. ---
# Chat + PRD + conversational local LLM:
LLAMA_N_GPU_LAYERS=-1
# Embeddings default CPU (0): chat + VLM OCR + embed on one GPU often OOMs ("Failed to create llama_context").
# Set -1 only if you have spare VRAM. On failure, load tries LLAMA_N_GPU_LAYERS_EMBED_PARTIAL GPU layers, then CPU.
# LLAMA_N_GPU_LAYERS_EMBED_PARTIAL=32
LLAMA_N_GPU_LAYERS_EMBED=0
LLAMA_MAIN_GPU=0
# LLAMA_N_CTX=8192
# LLAMA_EMBED_N_CTX=8192
# LLAMA_THREADS=0
# LLAMA_N_BATCH=512
# LLAMA_CHAT_FORMAT=
# LOCAL_CHAT_MAX_TOKENS=384
# LOCAL_CHAT_CPU_HISTORY_MESSAGES=8
# LOCAL_CHAT_CPU_MSG_CHAR_CAP=2000
# PRD / long doc generations when LLM_PROVIDER=local (default 4096; 8192 on CPU is very slow). 0 = no cap.
# LOCAL_DOC_GENERATION_MAX_TOKENS=4096
# Preload GGUF at startup so /docs isn’t “ready” while first request still loads for minutes (default on).
# LOCAL_LLM_WARMUP_ON_STARTUP=true
# LOCAL_LLM_WARMUP_EMBED_ON_STARTUP=false

# --- Advanced RAG (/api/v1/rag/*) — BM25 + Chroma + LangGraph; Jina + Qwen via llama-cpp-python ---
# Uses LOCAL_CHAT_GGUF_PATH / LOCAL_EMBEDDING_GGUF_PATH when RAG-specific paths are unset (second in-proc Llama handles).
# RAG_LLM_GGUF_PATH=
# Default 8192 — 32k + 9B + Jina embed on one GPU often fails llama_context; raise if you have headroom.
# RAG_LLM_N_CTX=8192
RAG_LLM_N_GPU_LAYERS=-1
# If RAG_LLM_N_GPU_LAYERS=-1 fails, try this many layers before CPU (default 32).
# RAG_LLM_N_GPU_LAYERS_PARTIAL=32
# RAG_LLM_CHAT_FORMAT=qwen
# RAG_LLM_HF_REPO=unsloth/Qwen3.5-9B-GGUF
# RAG_LLM_HF_FILENAME=Qwen3.5-9B-Q6_K.gguf
# JINA_EMBED_LOCAL_PATH=
JINA_EMBED_N_GPU_LAYERS=-1
# MAX_RAG_CONTEXT_CHARS=64000
# Multipart PDF/docs for /api/v1/rag/ingest-file (and PRD-platform mount). Default 64 — must be ≤ nginx client_max_body_size (see scripts/nginx/gov-ai-proxy-limits.conf).
# RAG_INGEST_FILE_MAX_MB=64

# --- Voice Form Filling & STT ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TRANSLATE_MODEL=translategemma:4b
OLLAMA_EXTRACT_MODEL=llama3.2:1b
DEEPGRAM_API_KEY=your-deepgram-key

# --- Azure OpenAI (used for form extraction, OCR, summarization, and conversational chat) ---
AZURE_GPT_ENDPOINT=https://your-resource.openai.azure.com
AZURE_GPT_KEY=your-azure-key
AZURE_GPT_DEPLOYMENT=your-deployment-name
AZURE_GPT_API_VERSION=2025-04-01-preview

# Optional: same values as AZURE_* for compatibility
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=

# --- OpenAI (OCR, summarization, vision fallback) ---
OPENAI_API_KEY=your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- CORS (comma-separated origins the frontend is served from) ---
# Development:
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Production: add your frontend URL(s), e.g.:
# CORS_ORIGINS=https://your-app.vercel.app,https://yourdomain.com

# --- MLflow (optional tracking server; if not running, set false to skip) ---
# MLFLOW_ENABLED=false
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=Government AI Backend

# --- OCR ---
UPLOAD_DIR=uploads
# Full path to tesseract binary (fallback when VLM OCR is off or returns empty).
# Linux/macOS: TESSERACT_CMD=/usr/bin/tesseract
# Windows (typical): TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# OCR_RASTER_BACKEND=auto
# auto = use local VLM if LOCAL_OCR_VLM_* are set, else Tesseract; or force: vlm | tesseract
# Local VLM OCR (llama-cpp-python + mmproj). Handler: auto | qwen25_vl | glm_ocr
# auto uses glm_ocr when LOCAL_OCR_VLM_GGUF_PATH contains "glm-ocr" (case-insensitive), else qwen25_vl.
# LightOnOCR (Qwen2.5-VL): hf download noctrex/LightOnOCR-2-1B-GGUF …
# GLM-OCR: hf download ggml-org/GLM-OCR-GGUF GLM-OCR-Q8_0.gguf && hf download ggml-org/GLM-OCR-GGUF mmproj-GLM-OCR-Q8_0.gguf
# Example (replace snapshot hash from hf download output):
# LOCAL_OCR_VLM_GGUF_PATH=C:\Users\<you>\.cache\huggingface\hub\models--ggml-org--GLM-OCR-GGUF\snapshots\<hash>\GLM-OCR-Q8_0.gguf
# LOCAL_OCR_VLM_MMPROJ_PATH=C:\Users\<you>\.cache\huggingface\hub\models--ggml-org--GLM-OCR-GGUF\snapshots\<hash>\mmproj-GLM-OCR-Q8_0.gguf
# LOCAL_OCR_VLM_CHAT_HANDLER=auto
# LOCAL_OCR_VLM_GGUF_PATH=
# LOCAL_OCR_VLM_MMPROJ_PATH=
# Defaults mirror backend/backend lighton_ocr_image (user-only turn, temp 0, 4096 decode tokens).
# LOCAL_OCR_VLM_N_CTX=8192
# LOCAL_OCR_VLM_MAX_TOKENS=4096
LOCAL_OCR_VLM_N_GPU_LAYERS=-1
# Resize long side (px) before VLM to cut tokens / VRAM; 0 = no resize (default 768)
# LOCAL_OCR_VLM_MAX_IMAGE_SIDE=768
# If VLM output is garbage and Tesseract is missing, retry with these max sides (comma-separated; default 512,384,256).
# LOCAL_OCR_VLM_GARBAGE_RETRY_SIDES=512,384,256
# Legacy single side if SIDES is empty: LOCAL_OCR_VLM_GARBAGE_RETRY_MAX_SIDE=512
# Retries also use capped max_tokens + higher repeat_penalty + optional user-only (matches mini-backend shape).
# LOCAL_OCR_VLM_GARBAGE_RETRY_MAX_TOKENS=640
# LOCAL_OCR_VLM_GARBAGE_RETRY_REPEAT_PENALTY=1.35
# LOCAL_OCR_VLM_GARBAGE_RETRY_USER_ONLY=true
# jpeg_fitted = always PIL→JPEG (default). native_if_fits = raw file when within max side.
# LOCAL_OCR_VLM_DATA_URI_MODE=jpeg_fitted
# Optional: add system role (old behavior). Default off to match mini-backend OCR.
# LOCAL_OCR_VLM_INCLUDE_SYSTEM=false
# LOCAL_OCR_VLM_TEMPERATURE=0
# LOCAL_OCR_VLM_REPEAT_PENALTY=1.15
# Verbose llama.cpp / tensor dump; default false (set true only for debugging)
# LOCAL_OCR_VLM_VERBOSE=false
# Hide native llama.cpp stderr (add_text, clip dump) during VLM; serializes VLM with a lock — dev/single-worker only.
# LOCAL_OCR_VLM_SILENCE_STDERR_FD=false
# LOCAL_LLM_WARMUP_OCR_VLM_ON_STARTUP=false
# OCR_DB_FILE=ocr_documents.db

# --- Conversational AI (auth, chat, voice, documents, integrations) ---
CONVERSATIONAL_DATABASE_URL=sqlite+aiosqlite:///./citizen_assistant.db
SECRET_KEY=change-this-to-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
SUPPORTED_LANGUAGES=hi,en,bn,te,mr,ta,ur,gu,kn,or,pa,as,ml

# Sarvam AI (voice STT/TTS)
SARVAM_API_KEY=your-sarvam-api-key

# Government integrations (optional)
# UMANG_API_KEY=
# DIGILOCKER_API_KEY=
# DIGILOCKER_CLIENT_ID=

# Document upload (conversational)
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.xlsx

# --- PRD Platform (FAISS RAG, tab 6) ---
AZURE_OPENAI_EMBEDDING_API_KEY=
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-01
AZURE_GPT_51_KEY=
AZURE_GPT_51_ENDPOINT=https://your-codex-resource.cognitiveservices.azure.com
AZURE_GPT_51_DEPLOYMENT=gpt-5.2-codex
AZURE_GPT_51_API_VERSION=2025-04-01-preview
# Required for Codex: Responses API (?api-version=...), not chat completions
AZURE_GPT_51_RESPONSES_API_VERSION=preview
# PRD_PLATFORM_DB_FILE=prd_platform.db
# PRD_PLATFORM_MAX_ZIP_MB=50
# PRD_EMBEDDING_DIM=1536
# PRD_TECH_DOCS_RAG_TOP_K_PER_QUERY=12
# PRD_TECH_DOCS_RAG_MAX_CHARS=32000
# PRD_TECH_DOCS_MAX_CHUNKS_PER_FILE=3
# PRD_TECH_DOCS_PRIORITY_MAX_CHUNKS=24
# PRD_TECH_DOCS_PRIORITY_MAX_CHARS=12000

# --- Code Summarizer (/api/v1/code-summarize/*, reuses PRD index + embeddings) ---
# CODE_SUMMARIZER_MAX_INPUT_CHARS=120000
# LLM_PROVIDER=local: excerpt size is auto-capped to ~fit LLAMA_N_CTX (tune reserve if summaries clip too early)
# CODE_SUMMARIZER_LOCAL_CTX_RESERVE_TOKENS=2800
# CODE_SUMMARIZER_LOCAL_CHARS_PER_TOKEN=3.2
# CODE_SUMMARIZER_HARD_MAX_CHARS=500000
# CODE_SUMMARIZER_RAG_TOP_K=24
# CODE_SUMMARIZER_RAG_MAX_CHARS=28000
# In-process response cache (optional)
# CODE_SUMMARY_CACHE_ENABLED=false
# CODE_SUMMARY_CACHE_TTL_SECONDS=600
# Optional Redis URL for future distributed cache (not wired in v1)
# REDIS_URL=

# --- Neo4j (optional: CDG / import graph after PRD codebase ZIP upload) ---
# One KEY=value per line only — do not paste two keys on one line (e.g. NEO4J_ENABLED=trueNEO4J_URI=... breaks parsing).
# When disabled (default), ZIP upload and deletes work without a Neo4j server.
# NEO4J_ENABLED=false
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
# NEO4J_DATABASE=
# On sync errors, still return upload success if true (recommended until stable)
# NEO4J_SYNC_FAIL_OPEN=true
# Optional caps (0 = unlimited): trim file nodes / edges written per project
# NEO4J_MAX_GRAPH_NODES=0
# NEO4J_MAX_GRAPH_EDGES=0
