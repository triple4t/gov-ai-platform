# ============================================================
# Root — monorepo-wide (backend/ and frontend/ have own .gitignore)
# ============================================================

# --- Secrets at repository root ---
.env
.env.local
.env.*.local

# --- Certificates & keys ---
*.pem
*.key
!*.key.example

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE & editors ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Logs ---
logs/
*.log

# --- Optional: tooling at repo root ---
node_modules/
.turbo/
