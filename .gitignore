# ============================================================
# Root .gitignore — Voice-Based Form Filling & Conversational AI
# ============================================================

# --- Environment & secrets (never commit) ---
.env
.env.local
.env.*.local
*.pem

# --- Python / Backend ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Backend runtime / local data
uploads/
*.db
data/
*.sqlite3

# --- Node / Frontend ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
dist/
dist-ssr/
*.local

# --- IDE & OS ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Logs ---
logs/
*.log

# --- Optional: legacy / unused (uncomment if you keep the folder but don't want it in git)
# Backend-conversational-ai/
