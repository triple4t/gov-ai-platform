# Copy to the server and adjust (optional — you can export vars inline instead):
#   sudo mkdir -p /etc/gov-ai
#   sudo cp scripts/deploy.env.example /etc/gov-ai/deploy.env
#   sudo nano /etc/gov-ai/deploy.env
#
# Public URL of the site (no trailing slash). Used for Vite build (VITE_API_URL).
# Examples:
#   VITE_API_URL=https://government-ai.eastus.cloudapp.azure.com
#   VITE_API_URL=https://app.example.com
VITE_API_URL=

# Git branch to pull (default: main)
# GIT_BRANCH=main

# If requirements.txt changes broke your CUDA llama-cpp-python wheel, set to 1 once:
# LLAMA_CUDA_REINSTALL=0
#
# Nginx: deploy.sh installs scripts/nginx/gov-ai-proxy-limits.conf → /etc/nginx/snippets/
# You must add once inside the server or /api location: include /etc/nginx/snippets/gov-ai-proxy-limits.conf;
